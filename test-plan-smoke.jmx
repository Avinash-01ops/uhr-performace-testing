      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Inject Bearer Token" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">
String token = props.get(&quot;GLOBAL_AUTH_TOKEN&quot;);
if (token != null &amp;&amp; !token.isEmpty()) {
    vars.put(&quot;AUTH_TOKEN&quot;, token);
} else {
    log.warn(&quot;GLOBAL_AUTH_TOKEN not set - check Setup thread group ran successfully&quot;);
    vars.put(&quot;AUTH_TOKEN&quot;, &quot;MISSING_TOKEN&quot;);
}
          </stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Authorization Header" enabled="true">
          <collectionProp name="HeaderManager.headers">
            <elementProp name="Authorization" elementType="Header">
              <stringProp name="Header.name">Authorization</stringProp>
              <stringProp name="Header.value">Bearer ${AUTH_TOKEN}</stringProp>
            </elementProp>
            <elementProp name="Content-Type" elementType="Header">
              <stringProp name="Header.name">Content-Type</stringProp>
              <stringProp name="Header.value">application/json</stringProp>
            </elementProp>
          </collectionProp>
        </HeaderManager>
