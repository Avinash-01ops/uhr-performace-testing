        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <stringProp name="LoopController.loops">1</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </PostThreadGroup>
      <hashTree>
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Test Complete" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename" />
          <stringProp name="parameters" />
          <stringProp name="script">
log.info("=======================================================");
log.info("UHR ADT Performance Test COMPLETED");
log.info("Results in: results/ directory");
log.info("HTML report cmd: jmeter -g results/aggregate_report.csv -o results/html_report/");
log.info("=======================================================");
SampleResult.setResponseMessage("Test completed successfully");
SampleResult.setResponseCode("200");
SampleResult.setSuccessful(true);
          </stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree />
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
