          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename" />
          <stringProp name="parameters" />
          <stringProp name="script">
String token = props.get("GLOBAL_AUTH_TOKEN");
if (token != null &amp;&amp; !token.isEmpty()) {
    vars.put("AUTH_TOKEN", token);
} else {
    log.warn("GLOBAL_AUTH_TOKEN not set - check Setup thread group ran successfully");
    vars.put("AUTH_TOKEN", "MISSING_TOKEN");
}
          </stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>
